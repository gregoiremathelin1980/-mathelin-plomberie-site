# Copier vers .env.local pour le développement. Ne jamais committer de secrets.

# --- GéoComptaAE (API publique read-only, appels 100 % serveur — jamais NEXT_PUBLIC_* pour la clé) ---
# URL de base recommandée (Funnel Tailscale, ex. https://trigkey….ts.net:8443) — SANS slash final.
GEOCOMPTA_BASE_URL=
# Alias historiques vitrine (même valeur que GEOCOMPTA_BASE_URL si besoin).
GEOCOMPTA_API_BASE_URL=
GEOCOMPTA_API_URL=

# Optionnel — seulement si ton instance GéoComptaAE protège `GET /api/public/*` avec un **Bearer** dédié (ex. GEOCOMPTA_PUBLIC_API_KEY côté serveur).
# Si tu n’utilises **que** GeoVault (`GEO_VAULT_APP_*` sur le serveur) et **aucun** Bearer sur ces routes → laisse vide : le site vitrine **n’envoie pas** ce header.
# Brancher GeoVault dans ce repo = ajouter le contrat HTTP exact (noms d’en-têtes) dans `geocomptaClient.ts` ; ce n’est pas la même chose que GEOCOMPTA_API_KEY.
GEOCOMPTA_API_KEY=

# Dépannage avis (accueil) : **401** → Bearer attendu côté API mais absent ou faux ; ou auth autre (Vault) non implémentée côté vitrine.
# **[]** après parse (logs dev : longueur `/reviews` et `featuredReviews`) → pas d’avis en base côté GéoCompta ou champs hors contrat (rating, texte).
# **Timeout** → BASE_URL injoignable depuis l’hôte Next (ex. Vercel → machine Trigkey / pare-feu).

# Hôtes pour next/image (sans https://), séparés par des virgules — rebuild après changement (next.config.js).
GEOCOMPTA_IMAGE_HOSTS=

# ISR page d’accueil + cache homepage (secondes, défaut 1800).
GEOCOMPTA_HOME_REVALIDATE_SECONDS=

# Cache pool GET /api/public/reviews (secondes, défaut 900).
GEOCOMPTA_REVIEWS_CACHE_SECONDS=

# Nombre d’avis affichés sur l’accueil (défaut 6).
GEOCOMPTA_HOME_REVIEWS_DISPLAY_COUNT=

# --- Site ---
# Développement uniquement : avis d’exemple depuis site-data/reviews.json sur l’accueil (jamais en production).
SITE_DATA_HOME_REVIEWS=

# Mot de passe zone /admin
ADMIN_PASSWORD=

# Lien public vers la fiche Google (avis) — affiché si l’API ne renvoie pas encore d’avis (Maps / « Partager le lien » GMB).
NEXT_PUBLIC_GMB_REVIEWS_URL=

# Formulaire contact (Web3Forms)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Optionnel : base photos
PHOTO_BASE_URL=

# Optionnel : dossier site-data hors repo
SITE_DATA_DIR=
